[sub_resource type="GDScript" id="GDScript_4gyqm"]
script/source = "extends CharacterBody2D

# ============== إعدادات العدو ==============
@export var enemy_name: String = \"Goblin\"
@export var move_speed: float = 150.0
@export var attack_range: float = 40.0
@export var attack_cooldown: float = 1.2
@export var max_health: int = 100
@export var damage: int = 20
@export var experience_reward: int = 50

# ============== مراجع العقد ==============
@onready var animator: AnimatedSprite2D = $AnimatedSprite2D
@onready var collision_shape: CollisionShape2D = $CollisionShape2D
@onready var attack_timer: Timer = $AttackTimer
@onready var hurt_timer: Timer = $HurtTimer
@onready var health_bar: ProgressBar = $HealthBar

# ============== متغيرات الحالة ==============
var current_health: int
var is_attacking: bool = false
var is_dead: bool = false
var is_hurt: bool = false
var can_attack: bool = true
var current_attack: String = \"attack1\"
var player: Node2D = null

# ============== إشارات ==============
signal enemy_died(position, experience)
signal player_damaged(damage_amount)

# ============== دوال التهيئة ==============
func _ready():
	current_health = max_health
	_setup_timers()
	_find_player()
	_update_health_bar()
	
	add_to_group(\"enemies\")
	_update_animation(\"idle\")

func _setup_timers():
	attack_timer.wait_time = attack_cooldown
	attack_timer.one_shot = true
	attack_timer.timeout.connect(_on_attack_timer_timeout)
	
	hurt_timer.wait_time = 0.2
	hurt_timer.one_shot = true
	hurt_timer.timeout.connect(_on_hurt_timer_timeout)

func _find_player():
	player = get_tree().get_first_node_in_group(\"player\")

func _update_health_bar():
	if health_bar:
		health_bar.value = float(current_health) / max_health * 100
		var health_percentage = float(current_health) / max_health
		if health_percentage <= 0.3:
			health_bar.modulate = Color.RED
		elif health_percentage <= 0.6:
			health_bar.modulate = Color.YELLOW
		else:
			health_bar.modulate = Color.GREEN

# ============== دوال الحركة - يتحرك تلقائياً للاعب ==============
func _physics_process(delta):
	# إذا كان ميتاً أو يهاجم أو متأذي، لا يتحرك
	if is_dead or is_attacking or is_hurt:
		velocity = Vector2.ZERO
		move_and_slide()
		return
	
	# البحث عن اللاعب إذا لم يكن موجوداً
	if player == null:
		_find_player()
		if player == null:
			# إذا لم يوجد لاعب، يقف في مكانه
			velocity = Vector2.ZERO
			move_and_slide()
			_update_animation(\"idle\")
			return
	
	# حساب المسافة للاعب
	var distance_to_player = global_position.distance_to(player.global_position)
	
	# دائماً يتحرك نحو اللاعب بغض النظر عن المسافة
	_move_towards_player()
	
	# التحقق من إمكانية الهجوم
	if distance_to_player <= attack_range and can_attack and not is_attacking:
		_attack()

func _move_towards_player():
	if player == null:
		return
	
	# حساب اتجاه اللاعب
	var direction = global_position.direction_to(player.global_position)
	
	# التحرك نحو اللاعب
	velocity = direction * move_speed
	move_and_slide()
	
	# قلب السبرايت حسب الاتجاه
	_flip_sprite(direction.x)
	
	# تشغيل انيميشن الجري
	_update_animation(\"run\")

func _flip_sprite(direction_x: float):
	if direction_x != 0 and animator:
		animator.flip_h = direction_x < 0

# ============== دوال الهجوم ==============
func _attack():
	if not can_attack or is_attacking or is_dead:
		return
	
	is_attacking = true
	can_attack = false
	velocity = Vector2.ZERO
	
	# اختيار هجوم عشوائي
	var random_attack = randi() % 3 + 1
	current_attack = \"attack\" + str(random_attack)
	
	# تشغيل انيميشن الهجوم
	_update_animation(current_attack)
	
	# انتظار نصف ثانية لتطبيق الضرر
	await get_tree().create_timer(0.3).timeout
	
	# تطبيق الضرر على اللاعب
	_apply_damage_to_player()
	
	# انتظار انتهاء انيميشن الهجوم
	await get_tree().create_timer(0.4).timeout
	
	is_attacking = false
	attack_timer.start()

func _apply_damage_to_player():
	if player == null:
		return
	
	# التحقق من أن اللاعب في نطاق الهجوم
	var distance_to_player = global_position.distance_to(player.global_position)
	
	if distance_to_player <= attack_range:
		if player.has_method(\"take_damage\"):
			player.take_damage(damage, self)
			player_damaged.emit(damage)
			
			# تأثير عند الضرب
			_create_hit_effect()

func _create_hit_effect():
	modulate = Color.RED
	await get_tree().create_timer(0.1).timeout
	modulate = Color.WHITE

# ============== دوال استقبال الضرر ==============
func take_damage(amount: int, damage_source: Node2D = null):
	if is_dead or is_hurt:
		return
	
	current_health -= amount
	_update_health_bar()
	
	is_hurt = true
	_update_animation(\"hurt\")
	
	# تأثير التراجع
	if damage_source:
		var knockback_direction = global_position.direction_to(damage_source.global_position) * -1
		velocity = knockback_direction * 200
		velocity.y = -100
		move_and_slide()
	
	# تأثير الوميض
	_flash_red()
	
	hurt_timer.start()
	
	if current_health <= 0:
		_die()

func _flash_red():
	var original_modulate = modulate
	modulate = Color.RED
	await get_tree().create_timer(0.1).timeout
	modulate = original_modulate

# ============== دوال الموت ==============
func _die():
	is_dead = true
	can_attack = false
	
	# تعطيل التصادم
	if collision_shape:
		collision_shape.disabled = true
	
	# إخفاء شريط الصحة
	if health_bar:
		health_bar.visible = false
	
	# تشغيل انيميشن الموت
	_update_animation(\"death\")
	
	# إرسال إشارة الموت
	enemy_died.emit(global_position, experience_reward)
	
	# انتظار انتهاء الانيميشن ثم الحذف
	await get_tree().create_timer(1.0).timeout
	queue_free()

# ============== دوال الانيميشن ==============
func _update_animation(animation_name: String):
	if is_dead or not animator:
		return
	
	var animations = [\"idle\", \"run\", \"jump\", \"hurt\", \"death\", \"attack1\", \"attack2\", \"attack3\"]
	
	if animation_name in animations:
		if animator.sprite_frames.has_animation(animation_name):
			animator.play(animation_name)
		else:
			# استخدم انيميشن بديل إذا لم يكن موجوداً
			match animation_name:
				\"attack1\", \"attack2\", \"attack3\":
					if animator.sprite_frames.has_animation(\"attack1\"):
						animator.play(\"attack1\")
				\"death\":
					if animator.sprite_frames.has_animation(\"die\"):
						animator.play(\"die\")
				_:
					if animator.sprite_frames.has_animation(\"idle\"):
						animator.play(\"idle\")

func _on_animation_finished():
	if not animator:
		return
	
	var finished = animator.animation
	
	if finished == \"attack1\" or finished == \"attack2\" or finished == \"attack3\":
		pass
	elif finished == \"hurt\":
		if not is_dead:
			is_hurt = false
			_update_animation(\"idle\")
	elif finished == \"death\":
		pass

# ============== دوال المؤقتات ==============
func _on_attack_timer_timeout():
	can_attack = true

func _on_hurt_timer_timeout():
	is_hurt = false
	if not is_dead and not is_attacking:
		_update_animation(\"idle\")
"

